# App
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=treeo_db
DB_USER=postgres
DB_PASSWORD=1234
DATABASE_URL=postgresql://postgres:1234@localhost:5432/treeo_db?schema=public

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Enable logger for local
LOG_TO_FILE=false
