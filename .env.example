# App
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Database
POSTGRES_DB=treeo2
POSTGRES_USER=treeo2_user
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_PORT=5432
DATABASE_URL=postgresql://treeo2_user:change-me-local-only@localhost:5432/treeo2?schema=public

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_ISSUER=treeo2-backend
JWT_AUDIENCE=treeo2-api

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Enable logger for local
LOG_TO_FILE=false

# Docs
SWAGGER_ENABLED=true
