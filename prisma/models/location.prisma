model Location {
  id        Int      @id @default(autoincrement())
  countryId Int      @map("country_id")
  parentId  Int?     @map("parent_id")
  level     Int
  name      String   @db.VarChar(200)
  code      String?  @db.VarChar(50)
  latitude  Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  country  Country   @relation(fields: [countryId], references: [id], onDelete: Restrict)
  parent   Location? @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Location[] @relation("LocationHierarchy")
  users    User[]     @relation("UserAdminLocation")
  projects Project[]  @relation("ProjectAdminLocation")

  @@index([countryId])
  @@index([parentId])
  @@map("locations")
}