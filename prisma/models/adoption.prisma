model Adoption {
  id        Int      @id @default(autoincrement()) @map("id")
  adopterId Int      @map("adopter_id")
  fobId     String   @map("fob_id") @db.VarChar(80)
  adoptedAt DateTime @map("adopted_at") @db.Date
  createdAt DateTime @default(now()) @map("created_at")

  adopter   Adopter  @relation(fields: [adopterId], references: [id], onDelete: Restrict)

  @@index([adopterId])
  @@map("Adoptions")
}
