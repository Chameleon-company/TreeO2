model TreeType {
  id               Int               @id @default(autoincrement())
  name             String            @db.VarChar(200)
  key              String?           @unique @db.VarChar(200)
  scientificName   String?           @map("scientific_name") @db.VarChar(200)
  dryWeightDensity Decimal           @default(595.0) @map("dry_weight_density") @db.Decimal(8, 3)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at")

  projectTreeTypes ProjectTreeType[]
  treeScans        TreeScan[]        @relation("SpeciesTreeScans")

  @@map("tree_types")
}
