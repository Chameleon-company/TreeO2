model LocalizedString {
  id          Int    @id @default(autoincrement())
  cultureCode String @map("culture_code") @db.VarChar(10)
  stringKey   String @map("string_key") @db.VarChar(255)
  value       String @db.Text
  context     String @db.VarChar(50) @map("context")

  culture     Culture @relation(fields: [cultureCode], references: [code], onDelete: Restrict)

  @@unique([cultureCode, stringKey, context])
  @@map("localized_strings")
}
