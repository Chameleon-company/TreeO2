model Country {
  id    Int     @id @default(autoincrement())
  name  String  @db.VarChar(100)
  iso2  String  @unique @db.Char(2)
  iso3  String? @unique @db.Char(3)

  locations Location[]
  administrativeLevels AdministrativeLevel[]
  users      User[]    @relation("UserCountry")
  projects   Project[] @relation("ProjectCountry")

  @@map("countries")
}