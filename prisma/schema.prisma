generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdministrativeLevel {
  id        Int     @id @default(autoincrement())
  countryId Int     @map("country_id")
  level     Int
  name      String  @db.VarChar(100)

  country   Country @relation(fields: [countryId], references: [id], onDelete: Restrict)

  @@index([countryId])
  @@map("administrative_levels")
}

model Adopter {
  id        Int        @id @default(autoincrement())
  name      String     @db.VarChar(255)
  email     String?    @db.VarChar(255)
  createdAt DateTime   @default(now()) @map("created_at")

  adoptions Adoption[]

  @@map("adopters")
}

model Adoption {
  id        Int      @id @default(autoincrement())
  adopterId Int      @map("adopter_id")
  fobId     String   @map("fob_id") @db.VarChar(80)
  adoptedAt DateTime @map("adopted_at") @db.Date
  createdAt DateTime @default(now()) @map("created_at")

  adopter   Adopter  @relation(fields: [adopterId], references: [id], onDelete: Restrict)

  @@index([adopterId])
  @@map("adoptions")
}

model Country {
  id                   Int                   @id @default(autoincrement())
  name                 String                @db.VarChar(100)
  iso2                 String                @unique @db.Char(2)
  iso3                 String?               @unique @db.Char(3)

  locations            Location[]
  administrativeLevels AdministrativeLevel[]

  @@map("countries")
}

model Culture {
  code             String            @id @db.VarChar(10)
  name             String            @db.VarChar(100)

  localizedStrings LocalizedString[]

  @@map("cultures")
}

model LocalizedString {
  id          Int     @id @default(autoincrement())
  cultureCode String  @map("culture_code") @db.VarChar(10)
  stringKey   String  @map("string_key") @db.VarChar(255)
  value       String  @db.Text
  context     String  @map("context") @db.VarChar(50)

  culture     Culture @relation(fields: [cultureCode], references: [code], onDelete: Restrict)

  @@unique([cultureCode, stringKey, context])
  @@map("localized_strings")
}

model Location {
  id        Int        @id @default(autoincrement())
  countryId Int        @map("country_id")
  parentId  Int?       @map("parent_id")
  level     Int
  name      String     @db.VarChar(200)
  code      String?    @db.VarChar(50)
  latitude  Decimal?   @db.Decimal(9, 6)
  longitude Decimal?   @db.Decimal(9, 6)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  country   Country    @relation(fields: [countryId], references: [id], onDelete: Restrict)
  parent    Location?  @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children  Location[] @relation("LocationHierarchy")

  @@index([countryId])
  @@index([parentId])
  @@map("locations")
}

model Partner {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("partners")
}

model Project {
  id               Int               @id @default(autoincrement())
  name             String            @db.VarChar(255)
  description      String?
  countryId        Int?              @map("country_id")
  adminLocationId  Int?              @map("admin_location_id")
  isActive         Boolean           @default(true) @map("is_active")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at")

  userProjects     UserProject[]
  projectTreeTypes ProjectTreeType[]
  scanBatches      ScanBatch[]       @relation("ProjectScanBatches")
  treeScans        TreeScan[]        @relation("ProjectTreeScans")

  @@map("projects")
}

model ProjectTreeType {
  projectId  Int      @map("project_id")
  treeTypeId Int      @map("tree_type_id")

  project    Project  @relation(fields: [projectId], references: [id])
  treeType   TreeType @relation(fields: [treeTypeId], references: [id])

  @@id([projectId, treeTypeId])
  @@map("project_tree_types")
}

model Report {
  id          Int       @id @default(autoincrement())
  reportType  String    @map("report_type") @db.VarChar(100)
  requestedBy Int?      @map("requested_by")
  status      String    @db.VarChar(50)
  parameters  Json      @db.JsonB
  outputUrl   String?   @map("output_url") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  user        User?     @relation("UserReports", fields: [requestedBy], references: [id], onDelete: SetNull)

  @@map("reports")
}

model Role {
  id              Int                  @id @default(autoincrement())
  name            String               @unique @db.VarChar(50)

  primaryUsers    User[]               @relation("PrimaryRole")
  roleAssignments UserRoleAssignment[]

  @@map("roles")
}

model ScanBatch {
  id          Int        @id @default(autoincrement())
  inspectorId Int        @map("inspector_id")
  projectId   Int        @map("project_id")
  uploadedAt  DateTime   @default(now()) @map("uploaded_at")

  inspector   User       @relation("ScanBatchInspector", fields: [inspectorId], references: [id], onDelete: Restrict)
  project     Project    @relation("ProjectScanBatches", fields: [projectId], references: [id], onDelete: Restrict)
  treeScans   TreeScan[]

  @@index([inspectorId])
  @@index([projectId])
  @@map("scan_batches")
}

model TreeScan {
  id                    Int             @id @default(autoincrement())
  fobId                 String          @map("fob_id") @db.VarChar(80)
  projectId             Int             @map("project_id")
  farmerId              Int             @map("farmer_id")
  inspectorId           Int             @map("inspector_id")
  speciesId             Int             @map("species_id")
  estimatedPlantedYear  Int             @map("estimated_planted_year")
  estimatedPlantedMonth Int             @map("estimated_planted_month")
  plantedDate           DateTime?       @map("planted_date") @db.Date
  heightM               Decimal?        @map("height_m") @db.Decimal(12, 3)
  circumferenceCm       Decimal?        @map("circumference_cm") @db.Decimal(12, 3)
  diameterCm            Decimal?        @map("diameter_cm") @db.Decimal(12, 3)
  latitude              Float?
  longitude             Float?
  photoId               String?         @map("photo_id") @db.Uuid
  batchId               Int?            @map("batch_id")
  deviceId              String?         @map("device_id") @db.VarChar(100)
  isArchived            Boolean         @default(false) @map("is_archived")
  isCorrected           Boolean         @default(false) @map("is_corrected")
  correctedBy           Int?            @map("corrected_by")
  correctionReason      String?         @map("correction_reason") @db.Text
  isValid               Boolean         @default(true) @map("is_valid")
  validationNotes       String?         @map("validation_notes") @db.Text
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @default(now()) @updatedAt @map("updated_at")

  project               Project         @relation("ProjectTreeScans", fields: [projectId], references: [id], onDelete: Restrict)
  farmer                User            @relation("FarmerTreeScans", fields: [farmerId], references: [id], onDelete: Restrict)
  inspector             User            @relation("InspectorTreeScans", fields: [inspectorId], references: [id], onDelete: Restrict)
  species               TreeType        @relation("SpeciesTreeScans", fields: [speciesId], references: [id], onDelete: Restrict)
  batch                 ScanBatch?      @relation(fields: [batchId], references: [id], onDelete: SetNull)
  correctedByUser       User?           @relation("CorrectedTreeScans", fields: [correctedBy], references: [id], onDelete: SetNull)
  audits                TreeScanAudit[]

  @@index([fobId])
  @@index([projectId])
  @@index([farmerId])
  @@index([speciesId])
  @@index([batchId])
  @@map("tree_scans")
}

model TreeScanAudit {
  id            Int      @id @default(autoincrement())
  treeScanId    Int      @map("tree_scan_id")
  changedBy     Int      @map("changed_by")
  changeReason  String   @map("change_reason") @db.Text
  oldData       Json     @map("old_data") @db.JsonB
  newData       Json     @map("new_data") @db.JsonB
  changedAt     DateTime @default(now()) @map("changed_at")

  treeScan      TreeScan @relation(fields: [treeScanId], references: [id], onDelete: Restrict)
  changedByUser User     @relation("TreeScanAuditChangedBy", fields: [changedBy], references: [id], onDelete: Restrict)

  @@map("tree_scan_audit")
}

model TreeType {
  id               Int               @id @default(autoincrement())
  name             String            @db.VarChar(200)
  key              String?           @db.VarChar(200)
  scientificName   String?           @map("scientific_name") @db.VarChar(200)
  dryWeightDensity Decimal           @default(595.0) @map("dry_weight_density") @db.Decimal(8, 3)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @default(now()) @updatedAt @map("updated_at")

  projectTreeTypes ProjectTreeType[]
  speciesTreeScans TreeScan[]        @relation("SpeciesTreeScans")

  @@map("tree_types")
}

model User {
  id                   Int                  @id @default(autoincrement())
  name                 String               @db.VarChar(100)
  email                String?              @unique @db.VarChar(300)
  passwordHash         String?              @map("password_hash") @db.VarChar(300)
  accessToken          String?              @map("access_token") @db.VarChar(100)
  accessTokenCreated   DateTime?            @map("access_token_created")
  canSignIn            Boolean              @default(true) @map("can_sign_in")
  roleId               Int                  @map("role")
  cardId               String?              @unique @map("card_id") @db.VarChar(80)
  governmentId         String?              @map("government_id") @db.VarChar(80)
  gender               String?              @default("Male") @db.VarChar(10)
  disability           Boolean              @default(false)
  countryId            Int?                 @map("country_id")
  adminLocationId      Int?                 @map("admin_location_id")
  streetAddress        String?              @map("street_address") @db.VarChar(500)
  preferredLanguage    String?              @map("preferred_language") @db.VarChar(10)
  photoId              String?              @map("photo_id") @db.VarChar(100)
  biography            String?
  notes                String?
  accountActive        Boolean              @default(true) @map("account_active")
  dateJoined           DateTime?            @map("date_joined")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @default(now()) @updatedAt @map("updated_at")

  primaryRole          Role                 @relation("PrimaryRole", fields: [roleId], references: [id])
  roleAssignments      UserRoleAssignment[]
  userProjects         UserProject[]
  reports              Report[]             @relation("UserReports")
  scanBatches          ScanBatch[]          @relation("ScanBatchInspector")
  farmerTreeScans      TreeScan[]           @relation("FarmerTreeScans")
  inspectorTreeScans   TreeScan[]           @relation("InspectorTreeScans")
  correctedTreeScans   TreeScan[]           @relation("CorrectedTreeScans")
  changedTreeScanAudits TreeScanAudit[]     @relation("TreeScanAuditChangedBy")

  @@map("users")
}

model UserProject {
  userId    Int     @map("user_id")
  projectId Int     @map("project_id")

  user      User    @relation(fields: [userId], references: [id])
  project   Project @relation(fields: [projectId], references: [id])

  @@id([userId, projectId])
  @@map("user_projects")
}

model UserRoleAssignment {
  userId Int   @map("user_id")
  roleId Int   @map("role_id")

  user   User  @relation(fields: [userId], references: [id])
  role   Role  @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}